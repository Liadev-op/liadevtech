  "WPFActivationStatus": {
    "Content": "Ver estado de activacion",
    "Description": "Muestra si Windows esta activado y hasta cuando (solo lectura, no modifica nada).",
    "category": "5__Windows: ISO y activacion",
    "panel": "1",
    "Type": "Button",
    "ButtonWidth": "300",
    "InvokeScript": [
      "$estado = (cscript //nologo \"$env:SystemRoot\\System32\\slmgr.vbs\" /xpr | Out-String).Trim(); if ([string]::IsNullOrWhiteSpace($estado)) { $estado = 'No se pudo obtener el estado de activacion.' }; [System.Windows.MessageBox]::Show($estado, 'Estado de activacion de Windows', 'OK', 'Information')"
    ]
  },
