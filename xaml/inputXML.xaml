                                           Foreground="{DynamicResource LabelboxForegroundColor}" Margin="2,0,0,8"/>
                                <Button Name="WPFLiadevPreset" Content="Perfil Liadev" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        BorderBrush="{DynamicResource ToggleButtonOnColor}" FontWeight="SemiBold"
                                        ToolTip="El perfil recomendado de Liadev Tech: Estandar + visor de fotos clasico, sin inicio rapido, sin GameDVR ni anuncios"/>
                                <Button Name="WPFstandard" Content="Estandar" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        ToolTip="Seleccion equilibrada para la mayoria de los usuarios"/>
                                <Button Name="WPFminimal" Content="Minimo" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        ToolTip="Cambios minimos y seguros"/>
                                <Button Name="WPFAdvanced" Content="Avanzado" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,12"
                                        ToolTip="Tweaks profundos para usuarios avanzados"/>

                                <TextBlock Text="Seleccion" Background="Transparent" FontWeight="SemiBold"
                                           FontSize="{DynamicResource HeaderFontSize}"
                                           Foreground="{DynamicResource LabelboxForegroundColor}" Margin="2,0,0,8"/>
                                <Button Name="WPFClearTweaksSelection" Content="Limpiar seleccion" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Name="WPFGetInstalledTweaks" Content="Ver tweaks aplicados" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Name="WPFAppxRemoval" Content="Quitar bloatware (AppX)" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

                                <TextBlock Text="Mantenimiento" Background="Transparent" FontWeight="SemiBold"
                                           FontSize="{DynamicResource HeaderFontSize}"
                                           Foreground="{DynamicResource LabelboxForegroundColor}" Margin="2,0,0,8"/>
                                <Button Name="WPFFlushDNS" Content="Limpiar cache DNS" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        ToolTip="Vacia la cache de resolucion DNS (ipconfig /flushdns)"/>
                                <Button Name="WPFRestartExplorer" Content="Reiniciar Explorador" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        ToolTip="Reinicia el proceso explorer.exe (barra de tareas y escritorio)"/>
                                <Button Name="WPFEmptyRecycleBin" Content="Vaciar papelera" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        ToolTip="Vacia la papelera de reciclaje de todas las unidades"/>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                                <TextBlock Background="Transparent" TextWrapping="Wrap" FontSize="11" Margin="2,0,2,10"
                                           Foreground="{DynamicResource MainForegroundColor}" Opacity="0.75">
                                    Pasa el mouse sobre cada opcion para ver su descripcion. Si tienes dudas, usa solo los perfiles recomendados.
                                </TextBlock>
                                <Button Name="WPFTweaksbutton" Content="Aplicar tweaks" Width="Auto" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                        Background="{DynamicResource ToggleButtonOnColor}" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                <Button Name="WPFUndoall" Content="Deshacer seleccionados" Width="Auto" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Grid Background="Transparent"/>
                        </DockPanel>
                    </Border>

                    <!-- Contenido de tweaks -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid Name="tweakspanel" Background="Transparent">
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Config" Visibility="Collapsed" Name="WPFTab3">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="{DynamicResource TabContentMargin}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Name="featurespanel" Grid.Column="0" Background="Transparent">
                        </Grid>

                        <!-- Actualizaciones de Windows -->
                        <StackPanel Grid.Column="1" Margin="5">
                            <Border Background="{DynamicResource GroupBorderBackgroundColor}" CornerRadius="8" Margin="2,10,12,6" HorizontalAlignment="Stretch">
                                <TextBlock Text="Actualizaciones de Windows" Background="Transparent" FontWeight="SemiBold"
                                           FontSize="{DynamicResource HeaderFontSize}" Foreground="#FFFFFF" Padding="10,3,10,4"/>
                            </Border>

                            <!-- Perfil por defecto -->
                            <Border Background="{DynamicResource MainBackgroundColor}"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="10" Margin="2,6,12,6" Padding="0">
                                <StackPanel>
                                    <Border Background="{DynamicResource ButtonBackgroundColor}" CornerRadius="10,10,0,0" Padding="10,6">
                                        <TextBlock Text="Por defecto" Background="Transparent" FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource MainForegroundColor}" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Margin="14,8" TextWrapping="Wrap"
                                             Foreground="{DynamicResource MainForegroundColor}">
                                        Restaura la configuracion de Windows Update de fabrica y elimina cualquier politica previa.
                                    </TextBlock>
                                    <Button Name="WPFUpdatesdefault"
                                            FontSize="{DynamicResource ConfigTabButtonFontSize}"
                                            Content="Aplicar perfil por defecto"
                                            Margin="14,2,14,12" Width="Auto"
                                            Padding="10,4"/>
                                </StackPanel>
                            </Border>

                            <!-- Perfil seguridad -->
                            <Border Background="{DynamicResource MainBackgroundColor}"
                                    BorderBrush="{DynamicResource ToggleButtonOnColor}" BorderThickness="2"
                                    CornerRadius="10" Margin="2,6,12,6" Padding="0">
                                <StackPanel>
                                    <Border Background="{DynamicResource ToggleButtonOnColor}" CornerRadius="8,8,0,0" Padding="10,6">
                                        <TextBlock Text="Seguridad (recomendado)" Background="Transparent" FontWeight="Bold" FontSize="14"
                                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Margin="14,8" TextWrapping="Wrap"
                                             Foreground="{DynamicResource MainForegroundColor}">
                                        Nuevas funciones demoradas 365 dias, parches de seguridad a los 4 dias y sin drivers por Windows Update.
                                        <LineBreak/><Run FontStyle="Italic" FontSize="11">Nota: requiere Windows Pro (usa directivas de grupo).</Run>
                                    </TextBlock>
                                    <Button Name="WPFUpdatessecurity"
                                            FontSize="{DynamicResource ConfigTabButtonFontSize}"
                                            Content="Aplicar perfil de seguridad"
                                            Margin="14,2,14,12" Width="Auto"
                                            Padding="10,4"/>
                                </StackPanel>
                            </Border>

                            <!-- Desactivar todo -->
                            <Border Background="{DynamicResource MainBackgroundColor}"
                                    BorderBrush="#D9534F" BorderThickness="1"
                                    CornerRadius="10" Margin="2,6,12,6" Padding="0">
                                <StackPanel>
                                    <Border Background="#D9534F" CornerRadius="10,10,0,0" Padding="10,6">
                                        <TextBlock Text="Desactivar todo (no recomendado)" Background="Transparent" FontWeight="Bold" FontSize="14"
                                                   Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Margin="14,8" TextWrapping="Wrap"
                                             Foreground="{DynamicResource MainForegroundColor}">
                                        Desactiva TODAS las actualizaciones de Windows. Solo para equipos aislados o de prueba.
                                        <LineBreak/><Run FontStyle="Italic" FontSize="11" Foreground="#D9534F">Advertencia: el sistema queda vulnerable sin parches de seguridad.</Run>
                                    </TextBlock>
                                    <Button Name="WPFUpdatesdisable"
                                            FontSize="{DynamicResource ConfigTabButtonFontSize}"
                                            Content="Desactivar actualizaciones"
                                            Foreground="#D9534F"
                                            Margin="14,2,14,12" Width="Auto"
                                            Padding="10,4"/>
                                </StackPanel>
                            </Border>

                            <Grid Name="updatespanel" Background="Transparent">
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="AppX" Visibility="Collapsed" Name="WPFTab4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Grid.Row="0" Margin="{DynamicResource TabContentMargin}">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Background="{DynamicResource MainBackgroundColor}" Orientation="Vertical" Grid.Row="0" Grid.Column="0" Margin="5">
                                <Label Content="Seleccion:" FontSize="{DynamicResource FontSize}" VerticalAlignment="Center" Margin="2"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,2,0,0">
                                    <Button Name="WPFDefaultAppxSelection" Content=" Por defecto " Margin="2" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                                    <Button Name="WPFGetInstalledAppx" Content=" Ver instaladas " Margin="2" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                                    <Button Name="WPFSelectAllAppx" Content=" Seleccionar todo " Margin="2" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                                    <Button Name="WPFClearAppxSelection" Content=" Limpiar seleccion " Margin="2" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Name="appxpanel" Grid.Row="1">
                            </Grid>

                            <Border Grid.Row="2" Style="{StaticResource BorderStyle}" Margin="5,15,5,5">
                                <StackPanel Background="{DynamicResource MainBackgroundColor}" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Padding="10" TextWrapping="Wrap" Foreground="{DynamicResource MainForegroundColor}">
                                        Nota: selecciona las apps preinstaladas de Windows (AppX) que quieras quitar y pulsa 'Quitar seleccionadas'.
                                        <LineBreak/>Los paquetes se quitan para el usuario actual y para los perfiles nuevos.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="{DynamicResource MainBackgroundColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="5" HorizontalAlignment="Stretch" Padding="10">
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Button Name="WPFBackToTweaks" Content="Volver a Tweaks" Margin="5" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                            <Button Name="WPFRemoveSelectedAppx" Content="Quitar seleccionadas" Margin="5" Width="{DynamicResource ButtonWidth}" Height="{DynamicResource ButtonHeight}"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Barra de estado (Liadev Tech) -->
        <Border Grid.Row="3" Background="{DynamicResource MainBackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="12,5">
            <DockPanel LastChildFill="True">
                <ProgressBar Name="StatusBarProgress" DockPanel.Dock="Right" Width="180" Height="12"
                             Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"
                             Foreground="{DynamicResource ProgressBarForegroundColor}"
                             Background="{DynamicResource ButtonBackgroundColor}" BorderThickness="0" Margin="10,0,0,0"/>
                <TextBlock Name="StatusBarText" Text="Listo" Background="Transparent" VerticalAlignment="Center"
                           FontSize="12" Foreground="{DynamicResource MainForegroundColor}" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
